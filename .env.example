# Node Configuration
NODE_ID=node_1
NODE_PORT=8001
CLUSTER_PEERS=localhost:8002,localhost:8003,localhost:8004

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Consensus Configuration
HEARTBEAT_INTERVAL=0.5
ELECTION_TIMEOUT_MIN=1.5
ELECTION_TIMEOUT_MAX=3.0

# Lock Configuration
DEADLOCK_DETECTION_INTERVAL=5
MAX_LOCK_WAIT_TIME=30

# Cache Configuration
CACHE_MAX_SIZE=1000
CACHE_TTL=3600
CACHE_EVICTION_POLICY=LRU

# Queue Configuration
QUEUE_REPLICATION_FACTOR=3
QUEUE_PERSISTENCE_ENABLED=true

# Security Configuration
ENABLE_ENCRYPTION=true
ENABLE_AUDIT=true
AUTH_ENABLED=true
API_KEYS=admin-key:admin,operator-key:operator,viewer-key:viewer
AUDIT_LOG_PATH=data/audit.log
AUDIT_HASH_PATH=data/audit.hash
ENCRYPTION_SECRET=distributed-sync-secret

# Bonus Feature Configuration
GEO_REGION=asia-southeast
GEO_REGION_MAP=asia-southeast:22,us-east:70,eu-west:95
PBFT_FAULT_TOLERANCE_OVERRIDE=0

# Logging
LOG_LEVEL=INFO
